# space-dynamic-viewer environment template
# Copy this file to .env, then fill in real values in .env only.
# Do not commit .env, cookies, tokens, or API keys.

# ============================================================
# Required: target Bilibili UIDs
# ============================================================
# Required. One or more UP 主 UID values, separated by commas.
# Example: BILI_HOST_MIDS=1420210197,123456
BILI_HOST_MIDS=

# ============================================================
# Required: Bilibili login credential
# ============================================================
# Required: fill at least one of BILI_COOKIE or BILI_SESSDATA.
# Recommended: BILI_COOKIE, copied from a browser request on bilibili.com.
# BILI_COOKIE is more stable for charge-only dynamics, refresh, and risk-control recovery.
BILI_COOKIE=

# Alternative to BILI_COOKIE. This is only the SESSDATA value from the cookie.
BILI_SESSDATA=

# ============================================================
# Recommended: PushPlus notification
# ============================================================
# Recommended. PushPlus token for sending dynamic notifications.
# Leave empty if you only want local downloads without PushPlus messages.
PUSHPLUS_TOKEN=

# Optional. Group/topic code for PushPlus group push.
PUSHPLUS_TOPIC=

# Optional. PushPlus API endpoint and fallback message format.
PUSHPLUS_URL=https://www.pushplus.plus/send/
PUSHPLUS_TITLE=Bilibili dynamic update
PUSHPLUS_TEMPLATE=html
PUSHPLUS_MAX_CONTENT_CHARS=20000

# ============================================================
# Service polling
# ============================================================
# Optional. Poll interval in seconds.
SERVICE_INTERVAL_SECONDS=60

# Optional. Max dynamic pages checked per polling cycle.
SERVICE_MAX_PAGES_PER_POLL=3

# Optional. First-run behavior: now, today, or all.
# now   = only monitor new dynamics after service start.
# today = start from today's 00:00.
# all   = backfill as far as the API allows.
SERVICE_INITIAL_SINCE=now

# Optional. Pause duration after Bilibili risk-control codes -352 or -412.
SERVICE_BAN_BACKOFF_MINUTES=30

# Optional. Where downloaded text, images, audio, OCR, state, and auth files are stored.
DOWNLOAD_ROOT=./downloads

# Optional. Override service state file path.
SERVICE_STATE_FILE=

# Optional. Number of seen dynamic IDs kept in service state.
SERVICE_SEEN_LIMIT=2000

# Optional. Set to 0 to disable audio/subtitle download in service mode.
SERVICE_DOWNLOAD_AUDIO=1

# ============================================================
# Login refresh and QR recovery
# ============================================================
# Optional. Persisted auth state file. Defaults to DOWNLOAD_ROOT/.bili-auth.json.
BILI_AUTH_FILE=

# Optional. One QR login wait timeout, in milliseconds.
BILI_QR_TIMEOUT_MS=180000

# Optional. Retry delay after QR code expires, in milliseconds. Minimum is 30000.
BILI_QR_RETRY_DELAY_MS=60000

# Optional. A charge-only dynamic ID used to check whether login can still see restricted content.
# Leave empty to use the normal Bilibili nav check.
LOGIN_CHECK_DYNAMIC_ID=

# ============================================================
# Optional webhook
# ============================================================
# Optional. Custom webhook endpoint that receives the full JSON payload.
WEBHOOK_URL=

# Optional. JSON object for webhook request headers.
# Example: WEBHOOK_HEADERS_JSON={"Authorization":"Bearer xxx"}
WEBHOOK_HEADERS_JSON={}

# Optional. Webhook timeout in milliseconds.
WEBHOOK_TIMEOUT_MS=15000

# ============================================================
# Image OCR
# ============================================================
# Optional. Set to 0 to disable image OCR.
SERVICE_IMAGE_OCR=1

# Optional. tesseract, qwen-vl, or a provider starting with qwen.
IMAGE_OCR_PROVIDER=tesseract

# Optional. Qwen VL model name when IMAGE_OCR_PROVIDER=qwen-vl.
IMAGE_OCR_MODEL=qwen3-vl-flash

# Optional. Tesseract languages.
OCR_LANG=chi_sim+eng

# Optional. Tesseract page segmentation mode.
OCR_PSM=

# Optional. Custom OCR command. Supported placeholders: {input}, {output}.
# IMAGE_OCR_CMD=tesseract "{input}" stdout -l chi_sim+eng

# Optional. Custom OCR prompt for Qwen VL.
IMAGE_OCR_PROMPT=

# Optional. Qwen VL compatible API endpoint override.
DASHSCOPE_VL_BASE_URL=

# ============================================================
# Audio transcription / ASR
# ============================================================
# Optional. Qwen ASR API key. If set, Qwen is preferred automatically.
DASHSCOPE_API_KEY=

# Optional. DashScope base URL override.
DASHSCOPE_BASE_URL=

# Optional. DashScope async ASR API base URL override.
DASHSCOPE_ASYNC_BASE_URL=

# Optional. Groq API key. Used when DASHSCOPE_API_KEY is empty or provider is forced to groq.
GROQ_API_KEY=

# Optional. Local whisper command. Supported placeholders: {input}, {outdir}.
WHISPER_CMD=

# ============================================================
# Web UI
# ============================================================
# Optional. Local web server port for npm start.
PORT=5173
